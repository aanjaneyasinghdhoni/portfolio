---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Writings · Aanjaneya Singh Dhoni"
  description="Technical writeups on AI security, rogue AI threat analysis, and cybersecurity from a Cyber Security Consultant at PwC Frankfurt."
>
  <Nav />
  <main id="main-content" class="blog-main">
    <div class="container">
      <p class="section-label" data-reveal>// field notes · technical writings</p>
      <h1 class="section-title" data-reveal>WRITINGS</h1>

      {
        posts.length === 0 ? (
          <p class="empty mono">// no writeups yet — check back soon</p>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="post-card" data-reveal>
                <div class="card-meta mono">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.readingTime && (
                    <>
                      <span class="sep">·</span>
                      <span>{post.data.readingTime}</span>
                    </>
                  )}
                </div>
                <h2 class="card-title">{post.data.title}</h2>
                <p class="card-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="card-tags">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <span class="card-read mono">Read writeup →</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>

<style>
  .blog-main {
    padding-top: 100px;
    padding-bottom: 6rem;
    min-height: 100vh;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.75rem;
    text-decoration: none;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .post-card:hover {
    border-color: var(--gold-dim);
    transform: translateY(-2px);
  }

  .post-card:hover .card-read {
    color: var(--gold);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--gold);
  }

  .sep {
    color: var(--gold-dim);
  }

  .card-title {
    font-family: var(--font-hero);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    letter-spacing: 0.04em;
    color: var(--text-primary);
    line-height: 1.15;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.75;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--border);
    padding: 0.2em 0.55em;
    background: var(--bg-surface);
  }

  .card-read {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    transition: color 0.2s;
    margin-top: auto;
  }

  .empty {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
</style>
