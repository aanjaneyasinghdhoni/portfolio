---
---
<section class="hero" id="home">
  <!-- Cursor spotlight -->
  <div class="spotlight" id="hero-spotlight" aria-hidden="true"></div>

  <!-- Scanlines overlay -->
  <div class="scanlines" aria-hidden="true"></div>

  <!-- Background grid -->
  <div class="grid-bg" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-tag mono hero-entry">
      <span class="led"></span>
      Cloud Security &amp; Data Privacy Consultant · PwC Frankfurt
    </div>

    <div class="hero-name-wrap hero-entry">
      <h1 class="hero-name" id="hero-name">AANJANEYA<br/>SINGH DHONI</h1>
      <h1 class="hero-name glitch-layer" aria-hidden="true">AANJANEYA<br/>SINGH DHONI</h1>
    </div>

    <p class="hero-sub mono hero-entry">
      <span class="gold">&gt;</span> Penetration Tester · Cloud Security · Zero Trust Architect
    </p>

    <div class="hero-badges hero-entry">
      <span class="badge badge-gold">Bug Bounty HOF</span>
      <span class="badge">Fortune 500</span>
      <span class="badge">5+ Years</span>
      <span class="badge">M.S. Cybersecurity</span>
    </div>

    <div class="hero-actions hero-entry">
      <a href="#experience" class="btn-primary">View Experience</a>
      <a href="#contact" class="btn-ghost">Get In Touch</a>
      <a href="/resume.pdf" download class="btn-ghost btn-download" aria-label="Download Resume PDF">
        <span aria-hidden="true">↓</span> Resume
      </a>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--hero-glow) 0%, transparent 70%),
              var(--bg-void);
  transition: background-color 0.3s ease;
}

/* ── Grid background ── */
.grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
}

/* ── Scanlines ── */
.scanlines {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, var(--scanline-opacity)) 2px,
    rgba(0, 0, 0, var(--scanline-opacity)) 4px
  );
  pointer-events: none;
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 80px;
}

/* Hidden before motion JS runs */
.hero-entry {
  opacity: 0;
}

/* ── Tag ── */
.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

.led {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
  animation: pulse-glow 2s ease-in-out infinite;
  box-shadow: 0 0 8px var(--gold);
}

/* ── Name ── */
.hero-name-wrap {
  position: relative;
  margin-bottom: 1.5rem;
}

.hero-name {
  font-family: var(--font-hero);
  font-size: clamp(3rem, 8vw, 7rem);
  letter-spacing: 0.03em;
  line-height: 0.9;
  color: var(--text-primary);
}

.hero-name.glitch-layer {
  position: absolute;
  top: 0; left: 0;
  color: var(--gold);
  animation: glitch 0.4s steps(1) 0.6s 3 forwards;
  opacity: 0;
}

.hero-name.glitch-layer {
  animation-fill-mode: both;
}

@keyframes glitch-appear {
  0%   { opacity: 1; clip-path: inset(40% 0 61% 0); transform: translate(-4px); }
  25%  { clip-path: inset(20% 0 50% 0); transform: translate(3px); }
  50%  { clip-path: inset(60% 0 10% 0); transform: translate(-2px); }
  75%  { clip-path: inset(10% 0 70% 0); transform: translate(2px); }
  100% { opacity: 0; }
}

.hero-name.glitch-layer {
  animation: glitch-appear 0.5s steps(1) 0.4s 2 forwards;
}

/* ── Sub ── */
.hero-sub {
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 2rem;
}

/* ── Badges ── */
.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}

.badge {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.3rem 0.75rem;
  border: 1px solid var(--border);
  color: var(--text-muted);
  background: var(--bg-surface);
}

.badge-gold {
  border-color: var(--gold-dim);
  color: var(--gold);
  background: rgba(240,180,41,0.06);
}

/* ── Buttons ── */
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.75rem 2rem;
  background: var(--gold);
  color: var(--bg-void);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s;
  clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}

.btn-primary:hover {
  background: #ffd166;
  transform: translateY(-1px);
}

.btn-ghost {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.75rem 2rem;
  border: 1px solid var(--gold-dim);
  color: var(--gold);
  text-decoration: none;
  transition: all 0.2s;
  background: transparent;
  clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}

.btn-ghost:hover {
  background: rgba(240, 180, 41, 0.18);
  border-color: var(--gold);
  color: var(--text-primary);
}

/* ── Cursor spotlight ── */
.spotlight {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background: radial-gradient(
    600px circle at var(--x, 50%) var(--y, 50%),
    rgba(240, 180, 41, 0.07) 0%,
    rgba(240, 180, 41, 0.03) 30%,
    transparent 70%
  );
  opacity: 0;
  transition: opacity 0.4s ease;
}

.spotlight.visible {
  opacity: 1;
}

/* ── Bottom fade ── */
.hero-fade {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120px;
  background: linear-gradient(transparent, var(--bg-void));
  pointer-events: none;
}
</style>

<script>
  import { animate, stagger } from 'motion';

  const hero      = document.querySelector('.hero') as HTMLElement;
  const spotlight = document.getElementById('hero-spotlight') as HTMLElement;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    // Staggered spring entrance — each hero element slides up in sequence
    const heroEntries = hero.querySelectorAll('.hero-entry');
    animate(
      heroEntries,
      { opacity: [0, 1], y: [32, 0] },
      {
        duration: 0.7,
        delay: stagger(0.12, { start: 0.15 }),
        easing: [0.22, 1, 0.36, 1],
      }
    );

    function moveSpotlight(x: number, y: number) {
      spotlight.style.setProperty('--x', `${x}%`);
      spotlight.style.setProperty('--y', `${y}%`);
      spotlight.classList.add('visible');
    }

    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      moveSpotlight(
        ((e.clientX - rect.left) / rect.width)  * 100,
        ((e.clientY - rect.top)  / rect.height) * 100
      );
    });

    hero.addEventListener('mouseleave', () => {
      spotlight.classList.remove('visible');
    });

    hero.addEventListener('touchmove', (e: TouchEvent) => {
      const touch = e.touches[0];
      const rect  = hero.getBoundingClientRect();
      moveSpotlight(
        ((touch.clientX - rect.left) / rect.width)  * 100,
        ((touch.clientY - rect.top)  / rect.height) * 100
      );
    }, { passive: true });

    hero.addEventListener('touchend', () => {
      spotlight.classList.remove('visible');
    });
  } else {
    // Reduced motion: show all hero entries immediately
    hero.querySelectorAll('.hero-entry').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
    });
  }
</script>
