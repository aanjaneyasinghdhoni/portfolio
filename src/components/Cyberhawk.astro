---
const stats = [
  { value: "100K+", label: "Followers" },
  { value: "200+",  label: "Students Trained" },
  { value: "3 yrs", label: "Community Built" },
];

// ── Replace VIDEO_ID_X with your actual YouTube video IDs ──
// Get them from the URL: youtube.com/watch?v=VIDEO_ID
const videos = [
  { id: "v4wR6VypEjQ", title: "Cyberhawk Security — Featured Video" },
  { id: "BE4k4zuSzss", title: "Cyberhawk Security — Video 2" },
  { id: "kwePER0er84", title: "Cyberhawk Security — Video 3" },
  { id: "rqSg0EC7tm8", title: "Cyberhawk Security — Video 4" },
];
---

<section class="cyberhawk" id="cyberhawk" data-reveal>
  <div class="container">
    <p class="section-label">// community · content · education</p>
    <h2 class="section-title">CYBERHAWK<br/><span class="gold">SECURITY</span></h2>

    <!-- Top: info + stats -->
    <div class="cyhawk-top">
      <div class="cyhawk-text">
        <p class="cyhawk-body">
          Founded and scaled a cybersecurity education brand across YouTube, Instagram, and Twitter.
          Built from zero to <span class="gold">100,000+ followers</span> in 3 years through original
          content, expert interviews, and hands-on training.
        </p>
        <p class="cyhawk-body">
          Designed and delivered a full <span class="gold">Ethical Hacking &amp; Web App Penetration Testing</span> course —
          training 200+ students globally, end-to-end.
        </p>
        <a
          href="https://www.youtube.com/@CyberHawkSecurity"
          target="_blank"
          rel="noopener noreferrer"
          class="cyhawk-cta mono"
        >
          Visit Channel <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="cyhawk-stats">
        {stats.map(s => (
          <div class="cyhawk-stat">
            <span class="cyhawk-val mono">{s.value}</span>
            <span class="cyhawk-label mono">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Horizontal video scroll — full-width, outside container -->
  <div class="video-scroll-wrap" aria-label="Cyberhawk Security YouTube videos">
    <div class="video-track" role="list">
      {videos.map((v) => (
        <a
          class="video-card"
          href={`https://www.youtube.com/watch?v=${v.id}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Watch: ${v.title} on YouTube`}
          role="listitem"
        >
          <div class="video-thumb">
            <img
              src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`}
              alt={v.title}
              loading="lazy"
              width="320"
              height="180"
            />
            <div class="video-overlay" aria-hidden="true">
              <div class="play-btn">
                <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="video-info">
            <span class="video-title">{v.title}</span>
            <span class="video-tag mono">YouTube <span aria-hidden="true">↗</span></span>
          </div>
        </a>
      ))}
    </div>

    <!-- Scroll fade edges -->
    <div class="fade-left"  aria-hidden="true"></div>
    <div class="fade-right" aria-hidden="true"></div>
  </div>
</section>

<style>
.cyberhawk {
  padding: 6rem 0;
  background: var(--bg-void);
  border-top: 1px solid var(--border);
  overflow: hidden;
}

/* ── Top row ── */
.cyhawk-top {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: start;
  margin-bottom: 3.5rem;
}

.cyhawk-body {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.8;
  margin-bottom: 1.1rem;
}

.cyhawk-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--gold-dim);
  padding: 0.55rem 1.1rem;
  text-decoration: none;
  margin-top: 0.5rem;
  transition: background 0.2s, border-color 0.2s;
}

.cyhawk-cta:hover {
  background: rgba(240,180,41,0.1);
  border-color: var(--gold);
}

/* ── Stats ── */
.cyhawk-stats {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  border-left: 1px solid var(--border);
  padding-left: 2.5rem;
  min-width: 160px;
}

.cyhawk-stat { display: flex; flex-direction: column; gap: 0.2rem; }

.cyhawk-val {
  font-size: 2rem;
  color: var(--gold);
  font-weight: 500;
  line-height: 1;
  text-shadow: 0 0 16px rgba(240,180,41,0.35);
}

.cyhawk-label {
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* ── Video scroll ── */
.video-scroll-wrap {
  position: relative;
  width: 100%;
}

.video-track {
  display: flex;
  gap: 1.25rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding: 1rem 2rem 2.5rem;
  /* hide scrollbar but keep scroll */
  scrollbar-width: thin;
  scrollbar-color: var(--gold-dim) transparent;
}

.video-track::-webkit-scrollbar { height: 3px; }
.video-track::-webkit-scrollbar-track { background: transparent; }
.video-track::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 2px; }

/* ── Video card ── */
.video-card {
  flex: 0 0 300px;
  scroll-snap-align: start;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}

.video-card:hover {
  border-color: var(--gold-dim);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(240,180,41,0.1);
}

/* ── Thumbnail ── */
.video-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--bg-void);
}

.video-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  display: block;
  transition: transform 0.3s ease;
}

.video-card:hover .video-thumb img {
  transform: scale(1.04);
}

/* Play overlay */
.video-overlay {
  position: absolute;
  inset: 0;
  background: rgba(5, 5, 10, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.video-card:hover .video-overlay { opacity: 1; }

.play-btn {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--gold);
  color: var(--bg-void);
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 3px; /* optical center for play icon */
  box-shadow: 0 0 24px rgba(240,180,41,0.5);
}

/* ── Video info ── */
.video-info {
  padding: 0.85rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.video-title {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.video-tag {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold-dim);
}

/* ── Fade edges ── */
.fade-left, .fade-right {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 60px;
  pointer-events: none;
  z-index: 2;
}

.fade-left {
  left: 0;
  background: linear-gradient(90deg, var(--bg-surface), transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(-90deg, var(--bg-surface), transparent);
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .cyhawk-top {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .cyhawk-stats {
    flex-direction: row;
    border-left: none;
    border-top: 1px solid var(--border);
    padding-left: 0;
    padding-top: 1.5rem;
  }
  .video-card { flex: 0 0 260px; }
}

@media (max-width: 480px) {
  .video-card { flex: 0 0 220px; }
}
</style>
