{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=j.tool_input&&j.tool_input.file_path;if(f){require('child_process').execSync('npx prettier --write \"'+f+'\" --ignore-unknown',{stdio:'ignore'})}}catch(e){}});\"",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
